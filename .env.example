# ─── FisioSim Pro — Variáveis Globais de Ambiente ────────────────────────
# Esta é a configuração centralizada do ecossistema para rodar via Docker.

# PostgreSQL (Dados do banco local)
DATABASE_DB=fisiosim
DATABASE_USER=seu_usuario_local
DATABASE_PASS=sua_senha_local
DATABASE_PORT=5433
DATABASE_HOST=localhost

# URL Completa para o Prisma/Backend
DATABASE_URL="postgresql://USUARIO:SENHA@localhost:5433/fisiosim"