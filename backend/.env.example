# ─── FisioSim API — Variáveis de Ambiente ────────────────────────
# Copie este arquivo para .env e preencha com seus dados reais

# PostgreSQL (URL de conexão)
DATABASE_URL="postgresql://USUARIO:SENHA@localhost:5433/fisiosim?schema=fisiosim"

# Servidor
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# CORS — origens permitidas (Em dev: localhost. Em prod: URL da Vercel)
CORS_ORIGINS="http://localhost:5173,http://localhost:4173"