{
    "name": "fisiosim-api",
    "version": "1.0.0",
    "description": "FisioSim Pro — REST API Backend",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "test": "npm run test:db && npm run test:api",
        "test:db": "tsx tests/database_check.ts",
        "test:api": "tsx tests/api_integration.ts",
        "build": "tsc --project tsconfig.json",
        "start": "node dist/server.js",
        "db:generate": "prisma generate",
        "db:pull": "prisma db pull",
        "db:studio": "prisma studio"
    },
    "dependencies": {
        "@fastify/cors": "^9.0.1",
        "@fastify/sensible": "^5.6.0",
        "@prisma/client": "^5.22.0",
        "axios": "^1.13.6",
        "dotenv": "^16.4.5",
        "fastify": "^4.28.1",
        "pino-pretty": "^11.3.0",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@types/node": "^22.19.13",
        "prisma": "^5.22.0",
        "tsx": "^4.19.2",
        "typescript": "^5.7.2"
    }
}
